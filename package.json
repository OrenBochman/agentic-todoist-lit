{
  "name": "agentic-todoist-lit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check:no-js-in-src": "if find src -type f -name '*.js' | grep -q .; then echo 'Error: JavaScript files found in src/. This project is TypeScript-only.' && find src -type f -name '*.js'; exit 1; else echo 'OK: no JavaScript files found in src/'; fi",
    "lint": "npm run check:no-js-in-src && eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier . --check"
  },
  "dependencies": {
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lit": "^1.15.0",
    "eslint-plugin-lit-a11y": "^4.1.3",
    "prettier": "^3.4.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
